{
	"compatibility_date": "2026-03-12",
	"compatibility_flags": [
		"global_fetch_strictly_public"
	],
	"name": "my-astro-app",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"routes": [
		{ "pattern": "rohin.dev", "custom_domain": true },
		{ "pattern": "www.rohin.dev", "custom_domain": true }
	]
}