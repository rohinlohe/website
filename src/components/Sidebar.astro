---
import { getCollection } from 'astro:content';

interface Props {
	currentSlug?: string;
}

const { currentSlug } = Astro.props;
const posts = await getCollection('posts');
const sortedPosts = posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<aside class="sidebar">
	<div class="sidebar-top">
		<div class="sidebar-header">
			<a href="/" class="site-title">posts</a>
		</div>
		<nav class="feed">
			<ul>
				{sortedPosts.map((post) => (
					<li>
						<a href={`/posts/${post.id}`} class:list={[{ active: post.id === currentSlug }]}>
							<span class="entry-title">{post.data.title}</span>
							<span class="entry-date">{new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}</span>
						</a>
					</li>
				))}
			</ul>
		</nav>
	</div>
	<div class="sidebar-bottom">
		<button class="subscribe-btn" id="subscribe-toggle">Subscribe</button>
		<form class="subscribe-form" id="subscribe-form">
			<div class="subscribe-input-row">
				<input type="email" placeholder="your email" required id="subscribe-email" />
				<button type="submit" class="subscribe-submit" aria-label="Submit">&rarr;</button>
			</div>
		</form>
	</div>
</aside>

<script>
	const toggle = document.getElementById('subscribe-toggle')!;
	const form = document.getElementById('subscribe-form')!;
	const emailInput = document.getElementById('subscribe-email')! as HTMLInputElement;

	toggle.addEventListener('click', () => {
		toggle.style.display = 'none';
		form.style.display = 'flex';
		emailInput.focus();
	});

	form.addEventListener('submit', (e) => {
		e.preventDefault();
		const email = emailInput.value;
		console.log('Subscribe:', email);
		emailInput.value = '';
		form.style.display = 'none';
		toggle.textContent = 'Subscribed!';
		toggle.style.display = 'inline-block';
		toggle.disabled = true;
	});
</script>

<style>
	.sidebar {
		width: 260px;
		height: 100vh;
		padding: 2rem 1.5rem 0;
		background-color: var(--bg-sidebar);
		border-right: none;
		background-image: linear-gradient(to bottom, color-mix(in srgb, var(--border), black 10%) 50%, transparent 50%);
		background-size: 2px 16px;
		background-repeat: repeat-y;
		background-position: right;
		position: fixed;
		top: 0;
		left: 0;
		overflow-y: auto;
		transition: background-color 0.2s ease, border-color 0.2s ease;
		display: flex;
		flex-direction: column;
		z-index: 101;
	}

	.sidebar-top {
		flex: 1;
	}

	.sidebar-bottom {
		height: 4.5rem;
		display: flex;
		align-items: center;
		flex-shrink: 0;
		padding-left: 0.6rem;
	}

	.subscribe-btn {
		font-family: var(--font-body);
		font-size: 0.85rem;
		padding: 0.4rem 1rem;
		border: none;
		border-radius: 0.375rem;
		cursor: pointer;
		background-color: #1a1a1a;
		color: #ffffff;
		transition: background-color 0.15s ease;
	}

	.subscribe-btn:hover:not(:disabled) {
		background-color: #333;
	}

	.subscribe-btn:disabled {
		opacity: 0.7;
		cursor: default;
	}

	:global([data-theme='dark']) .subscribe-btn {
		background-color: #e0e0e0;
		color: #1a1a1a;
	}

	:global([data-theme='dark']) .subscribe-btn:hover:not(:disabled) {
		background-color: #cccccc;
	}

	.subscribe-form {
		display: none;
		flex-direction: column;
		gap: 0.5rem;
		width: 100%;
	}

	.subscribe-form input[type="email"] {
		font-family: var(--font-body);
		font-size: 0.85rem;
		padding: 0.4rem 0.75rem;
		border: 1px solid var(--border);
		border-radius: 0.375rem;
		background-color: var(--bg-sidebar);
		color: var(--text);
		outline: none;
		width: 100%;
		transition: border-color 0.15s ease;
	}

	.subscribe-form input[type="email"]:focus {
		border-color: var(--accent);
	}

	.subscribe-input-row {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		width: 100%;
	}

	.subscribe-input-row input[type="email"] {
		flex: 1;
		min-width: 0;
	}

	.subscribe-submit {
		font-size: 1.2rem;
		padding: 0;
		border: none;
		cursor: pointer;
		background: none;
		color: var(--text);
		line-height: 1;
		transition: color 0.15s ease, transform 0.15s ease;
		flex-shrink: 0;
	}

	.subscribe-submit:hover {
		color: var(--accent);
		transform: translateX(2px);
	}

	.site-title {
		font-family: var(--font-heading);
		font-size: 1.25rem;
		font-weight: 459;
		color: var(--text);
		display: block;
		margin-bottom: 1rem;
		padding-left: 0.6rem;
	}

	.site-title:hover {
		color: var(--accent);
	}

	.feed ul {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.feed li {
		margin-bottom: 0.25rem;
	}

	.feed li a {
		display: flex;
		flex-direction: column;
		padding: 0.5rem 0.6rem;
		color: var(--text);
		border-radius: 0.375rem;
		transition: color 0.15s ease, background-color 0.15s ease;
	}

	.feed li a:hover {
		color: var(--accent);
	}

	.feed li a.active {
		background-color: rgba(176, 125, 79, 0.12);
		color: var(--accent);
	}

	:global([data-theme='dark']) .feed li a.active {
		background-color: rgba(212, 165, 116, 0.12);
	}

	.entry-title {
		font-size: 0.9rem;
	}

	.entry-date {
		font-size: 0.78rem;
		color: var(--text-muted);
	}

	@media (max-width: 768px) {
		.sidebar {
			position: static;
			width: 100%;
			min-height: auto;
			border-right: none;
			border-bottom: 1px solid var(--border);
		}
	}
</style>
