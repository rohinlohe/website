---
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');
const sortedPosts = posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<aside class="sidebar">
	<div class="sidebar-header">
		<a href="/" class="site-title">Rohin Garg</a>
	</div>
	<nav class="feed">
		<ul>
			{sortedPosts.map((post) => (
				<li>
					<a href={`/posts/${post.id}`}>
						<span class="entry-title">{post.data.title}</span>
						<span class="entry-date">{new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}</span>
					</a>
				</li>
			))}
		</ul>
	</nav>
</aside>

<style>
	.sidebar {
		width: 260px;
		min-height: 100vh;
		padding: 2rem 1.5rem;
		background-color: var(--bg-sidebar);
		border-right: 1px solid var(--border);
		position: fixed;
		top: 0;
		left: 0;
		overflow-y: auto;
		transition: background-color 0.2s ease, border-color 0.2s ease;
	}

	.site-title {
		font-family: var(--font-heading);
		font-size: 1.25rem;
		font-weight: 600;
		color: var(--text);
		display: block;
		margin-bottom: 2rem;
	}

	.site-title:hover {
		color: var(--accent);
	}

	.feed ul {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.feed li {
		margin-bottom: 0.25rem;
	}

	.feed li a {
		display: flex;
		flex-direction: column;
		padding: 0.5rem 0;
		color: var(--text);
		border-radius: 0.25rem;
		transition: color 0.15s ease;
	}

	.feed li a:hover {
		color: var(--accent);
	}

	.entry-title {
		font-size: 0.9rem;
	}

	.entry-date {
		font-size: 0.78rem;
		color: var(--text-muted);
	}

	@media (max-width: 768px) {
		.sidebar {
			position: static;
			width: 100%;
			min-height: auto;
			border-right: none;
			border-bottom: 1px solid var(--border);
		}
	}
</style>
